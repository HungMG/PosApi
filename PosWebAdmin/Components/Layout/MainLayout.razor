@inherits LayoutComponentBase

<div class="pos-app-container">
    
    <header class="app-header shadow-sm border-bottom">
        <div class="container-fluid d-flex justify-content-between align-items-center px-4 py-2">
            <h1 class="m-0 fs-5 fw-bold d-flex align-items-center gap-2">
                <div class="icon-box bg-primary text-white rounded-3 d-flex justify-content-center align-items-center">
                    ☕
                </div>
                <span>Cafe Vối Garden <span class="text-primary">Hub</span></span>
            </h1>
            
            <div class="d-flex align-items-center gap-2">
                <span class="badge bg-light text-dark border px-2 py-1 rounded-3">
                    <i class="bi bi-wifi text-success me-1"></i> Online
                </span>
            </div>
        </div>
    </header>

    <main class="app-main-content pb-5">
        <div class="content-wrapper">
            @Body
        </div>
    </main>

    <nav class="app-bottom-nav shadow-lg border-top">
        <div class="nav-container d-flex justify-content-around align-items-center h-100">
            
            <NavLink class="nav-btn" href="" Match="NavLinkMatch.All" ActiveClass="active-tab">
                <i class="bi bi-bar-chart-fill fs-4 mb-1"></i>
                <span>Thống kê</span>
            </NavLink>

            <NavLink class="nav-btn" href="products" ActiveClass="active-tab">
                <i class="bi bi-cup-straw fs-4 mb-1"></i>
                <span>Sản phẩm</span>
            </NavLink>

            <NavLink class="nav-btn" href="staff" ActiveClass="active-tab">
                <i class="bi bi-people-fill fs-4 mb-1"></i>
                <span>Nhân sự</span>
            </NavLink>

            <NavLink class="nav-btn" href="salary" ActiveClass="active-tab">
                <i class="bi bi-cash-coin fs-4 mb-1"></i>
                <span>Bảng lương</span>
            </NavLink>
            
        </div>
    </nav>
</div>

<style>
    /* Reset nền chung màu xám nhạt (như stone-50) */
    body {
        background-color: #f8fafc;
        font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    }

    .pos-app-container {
        display: flex;
        flex-direction: column;
        height: 100vh; /* Cố định chiều cao bằng đúng màn hình */
        overflow: hidden;
    }

    /* --- HEADER --- */
    /* Viền Header trên cùng */
    .app-header {
        background-color: #ffffff;
        z-index: 1040;
        height: 60px;
        border-bottom: 3px solid #0d6efd !important; /* Thêm viền màu xanh Primary */
    }

    .icon-box {
        width: 32px;
        height: 32px;
        font-size: 1.1rem;
    }

    /* --- MAIN CONTENT --- */
    .app-main-content {
        flex: 1;
        overflow-y: auto;
        background-color: rgba(248, 250, 252, 0.7); /* natural-bg/70 */
        padding: 1rem;
    }

    /* Giới hạn khung nội dung trên Laptop để không bị bè ra quá xấu */
    .content-wrapper {
        max-width: 768px; /* Giữ form đẹp trên cả Laptop */
        margin: 0 auto;
        padding-bottom: 30px; /* Chừa không gian cho thanh Bottom Nav */
    }

    /* Viền thanh điều hướng dưới đáy */
    .app-bottom-nav {
        background-color: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
        height: 75px;
        position: fixed;
        bottom: 0;
        left: 0;
        width: 100%;
        z-index: 1050;
        border-radius: 20px 20px 0 0;
        border-top: 3px solid #0d6efd !important; /* Thêm viền màu xanh Primary */
    }

    .nav-container {
        max-width: 768px; /* Cùng kích thước với content-wrapper */
        margin: 0 auto;
    }

    .nav-btn {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        color: #64748b; /* slate-500 */
        text-decoration: none;
        width: 25%;
        transition: all 0.2s ease-in-out;
    }

        .nav-btn span {
            font-size: 0.75rem;
            font-weight: 500;
            margin-top: 2px;
        }

    /* Hiệu ứng nảy khi Tab đang được chọn */
    .active-tab {
        color: #0d6efd !important; /* Màu Primary */
        transform: translateY(-4px); /* Giật nhẹ lên trên */
    }

        .active-tab i {
            color: #0d6efd;
        }
    
        .active-tab span {
            font-weight: 700;
        }

    /* Tùy chỉnh thanh cuộn tàng hình cho mượt */
    ::-webkit-scrollbar {
        width: 4px;
    }

    ::-webkit-scrollbar-thumb {
        background: #cbd5e1;
        border-radius: 10px;
    }
</style>