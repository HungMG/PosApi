@page "/products"
@using PosWebAdmin.Models
@using PosWebAdmin.Services
@inject ApiService ApiService
@inject IJSRuntime JSRuntime 

<div class="container-fluid py-3" style="max-width: 800px; margin: 0 auto;">
    
    <div class="d-flex bg-light p-1 rounded-pill mb-4 border shadow-sm">
        <button class="btn flex-fill rounded-pill py-2 transition-all @(activeTab == "products" ? "btn-primary fw-bold shadow" : "text-muted border-0")"
                @onclick='() => activeTab = "products"'>
            Sản phẩm (@products.Count)
        </button>
        
        <button class="btn flex-fill rounded-pill py-2 transition-all @(activeTab == "categories" ? "btn-primary fw-bold shadow" : "text-muted border-0")"
                @onclick='() => activeTab = "categories"'>
            Danh mục (@categories.Count)
        </button>
    </div>

    @if (activeTab == "products")
    {
        <div class="space-y-4">
            
            <button class="btn btn-primary w-100 fw-bold rounded-4 py-3 mb-3 shadow-sm d-flex justify-content-center align-items-center gap-2"
                    @onclick="ToggleAddProductForm">
                <i class="bi @(isAddingProduct ? "bi-x-circle-fill" : "bi-plus-circle-fill") fs-5"></i>
                @(isAddingProduct ? "ĐÓNG FORM" : "THÊM SẢN PHẨM MỚI")
            </button>

            @if (isAddingProduct)
            {
                <div class="card shadow-sm border-primary rounded-4 mb-3 bg-primary bg-opacity-10">
                    <div class="card-body">
                        <input type="text" class="form-control mb-2 rounded-3" @bind="newProduct.Name" placeholder="Tên món (VD: Bạc xỉu đá)..." />
                        <div class="row g-2 mb-2">
                            <div class="col-6">
                                <input type="number" class="form-control rounded-3" @bind="newProduct.Price" placeholder="Giá bán..." />
                            </div>
                            <div class="col-6">
                               <select class="form-select rounded-3" @bind="newProduct.CategoryId">
    <option value="0">-- Chọn danh mục --</option>
    @foreach (var parent in categories.Where(c => c.ParentId == null))
    {
        var children = categories.Where(c => c.ParentId == parent.Id).ToList();
        
        if (children.Any())
        {
            <optgroup label="📂 @parent.Name">
                <option value="@parent.Id">@parent.Name (Thư mục gốc)</option>
                
                @foreach (var child in children)
                {
                    <option value="@child.Id">↳ @child.Name</option>
                }
            </optgroup>
        }
        else
        {
            <option value="@parent.Id">📂 @parent.Name</option>
        }
    }
</select>
                            </div>
                        </div>
                        <button class="btn btn-success w-100 fw-bold rounded-3" @onclick="HandleSaveProduct">
                            @(isEditingProduct ? "CẬP NHẬT MÓN" : "LƯU MÓN MỚI")
                        </button>
                    </div>
                </div>
            }

            <div class="d-flex gap-2 mb-3 overflow-auto pb-2" style="white-space: nowrap;">
    <button class="btn btn-sm rounded-pill fw-bold px-3 transition-all @(filterCategoryId == 0 ? "btn-primary shadow" : "btn-outline-secondary bg-white")"
            @onclick="() => filterCategoryId = 0">
        Tất cả (@products.Count)
    </button>
    
    @foreach (var parent in categories.Where(c => c.ParentId == null))
    {
        var children = categories.Where(c => c.ParentId == parent.Id).ToList();
        
        <button class="btn btn-sm rounded-pill fw-bold px-3 transition-all @(filterCategoryId == parent.Id ? "btn-primary shadow" : "btn-outline-secondary bg-white")"
                @onclick="() => filterCategoryId = parent.Id">
            @parent.Name
        </button>
        
        @foreach (var child in children)
        {
            <button class="btn btn-sm rounded-pill fw-bold px-3 transition-all @(filterCategoryId == child.Id ? "btn-primary shadow" : "btn-outline-secondary bg-white")"
                    @onclick="() => filterCategoryId = child.Id">
                ↳ @child.Name
            </button>
        }
    }
</div>

            <div class="d-flex flex-column gap-3">
                @if (!FilteredProducts.Any())
                {
                    <div class="text-center text-muted py-4">
                        <i class="bi bi-box-seam fs-1"></i>
                        <p class="mt-2">Không có món nào trong danh mục này.</p>
                    </div>
                }
                else
                {
                    @foreach (var p in FilteredProducts)
                    {
                        <div class="card border-0 shadow-sm rounded-4">
                            <div class="card-body p-3 d-flex justify-content-between align-items-center">
                                <div>
                                    <h5 class="fw-bold mb-1 d-flex align-items-center gap-2">
                                        @p.Name
                                        
                                        <span class="badge bg-primary bg-opacity-10 text-primary border border-primary-subtle rounded-pill" style="font-size: 0.7rem;">
                                            <i class="bi bi-tag-fill me-1"></i> @(p.Category?.Name ?? "Chưa phân loại")
                                        </span>
                                    </h5>
                                    <div class="text-danger fw-bold font-monospace" style="font-size: 1.1rem;">
                                        @p.Price.ToString("N0")đ
                                    </div>
                                </div>
                                
                                <div class="d-flex gap-2">
                                    <button class="btn btn-sm btn-outline-secondary rounded-3" @onclick="() => ShowEditProductForm(p)">
                                        <i class="bi bi-pencil-square"></i>
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger rounded-3" @onclick="() => HandleDeleteProduct(p.Id)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    }

    @if (activeTab == "categories")
    {
        <div class="space-y-4">
            <button class="btn btn-success w-100 fw-bold rounded-4 py-3 mb-3 shadow-sm d-flex justify-content-center align-items-center gap-2"
                    @onclick="ToggleAddCategoryForm">
                <i class="bi @(isAddingCategory ? "bi-x-circle-fill" : "bi-folder-plus") fs-5"></i>
                @(isAddingCategory ? "ĐÓNG FORM" : "THÊM DANH MỤC NHANH")
            </button>

            @if (isAddingCategory)
            {
                <div class="card shadow-sm border-success rounded-4 mb-3 bg-success bg-opacity-10">
                    <div class="card-body">
                        <input type="text" class="form-control mb-2 rounded-3" @bind="newCategory.Name" placeholder="Tên danh mục..." />
                        
                        <div class="d-flex gap-3 mb-3">
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="catType" checked="@(!isSubCategory)" @onchange="@(() => isSubCategory = false)" />
                                <label class="form-check-label fw-bold">Thư mục Gốc</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="catType" checked="@isSubCategory" @onchange="@(() => isSubCategory = true)" />
                                <label class="form-check-label fw-bold text-success">Thư mục Con</label>
                            </div>
                        </div>

                        @if (isSubCategory)
                        {
                            <select class="form-select mb-2 rounded-3" @bind="selectedParentId">
                                <option value="0">-- Chọn danh mục cha --</option>
                                @foreach (var parent in categories.Where(c => c.ParentId == null))
                                {
                                    <option value="@parent.Id">@parent.Name</option>
                                }
                            </select>
                        }

                        <button class="btn btn-primary w-100 fw-bold rounded-3" @onclick="HandleSaveCategory">
                            @(isEditingCategory ? "CẬP NHẬT" : "TẠO MỚI")
                        </button>
                    </div>
                </div>
            }

           <div class="d-flex flex-column gap-2 mt-2">
                @foreach (var parent in categories.Where(c => c.ParentId == null))
                {
                    <div class="card border-0 shadow-sm rounded-4 bg-light border-start border-4 border-warning">
                        <div class="card-body p-3 d-flex justify-content-between align-items-center">
                            <div class="fw-bold text-dark fs-6">
                                <i class="bi bi-folder-fill text-warning me-2"></i> @parent.Name
                            </div>
                            
                            <div class="d-flex gap-2">
                                <button class="btn btn-sm btn-outline-secondary rounded-3 bg-white" @onclick="() => ShowEditCategoryForm(parent)">
                                    <i class="bi bi-pencil-square"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-danger rounded-3 bg-white" @onclick="() => HandleDeleteCategory(parent.Id)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </div>
                    </div>

                    @foreach (var child in categories.Where(c => c.ParentId == parent.Id))
                    {
                        <div class="card border-0 shadow-sm rounded-4 ms-5 mb-1"> <div class="card-body p-2 px-3 d-flex justify-content-between align-items-center">
                                <div class="text-success fw-medium" style="font-size: 0.95rem;">
                                    ↳ <i class="bi bi-tag-fill me-1 opacity-75"></i> @child.Name
                                </div>
                                
                                <div class="d-flex gap-2">
                                    <button class="btn btn-sm btn-outline-secondary border-0 rounded-3" @onclick="() => ShowEditCategoryForm(child)">
                                        <i class="bi bi-pencil-square"></i>
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger border-0 rounded-3" @onclick="() => HandleDeleteCategory(child.Id)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    }
</div>

<style>
    .transition-all { transition: all 0.3s ease; }
    /* Giấu thanh cuộn ngang để nhìn giống app điện thoại */
    ::-webkit-scrollbar { height: 4px; }
    ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
</style>

@code {
    private string activeTab = "products"; 
    
    private List<Product> products = new();
    private List<Category> categories = new();
    
    // --- BIẾN LỌC SẢN PHẨM ---
    private int filterCategoryId = 0; // 0 nghĩa là "Tất cả"
    
    // Logic lọc siêu thông minh
    private IEnumerable<Product> FilteredProducts 
    {
        get 
        {
            if (filterCategoryId == 0) return products;
            
            // Tìm xem thư mục đang chọn có thư mục con nào không
            var childCategoryIds = categories
                .Where(c => c.ParentId == filterCategoryId)
                .Select(c => c.Id)
                .ToList();
                
            // Bao gồm cả ID của chính nó (để lấy các món nằm thả rông ở gốc)
            childCategoryIds.Add(filterCategoryId);
            
            // Trả về những sản phẩm có CategoryId nằm trong danh sách trên
            return products.Where(p => childCategoryIds.Contains(p.CategoryId));
        }
    }

    // --- BIẾN SẢN PHẨM ---
    private bool isAddingProduct = false;
    private bool isEditingProduct = false;
    private int editingProductId = 0;
    private Product newProduct = new();
    
    // --- BIẾN DANH MỤC ---
    private bool isAddingCategory = false;
    private bool isEditingCategory = false;
    private int editingCategoryId = 0;
    private Category newCategory = new();
    private bool isSubCategory = false;
    private int selectedParentId = 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        categories = await ApiService.GetCategoriesAsync();
        products = await ApiService.GetProductsAsync();
    }

    // =====================================
    // LOGIC SẢN PHẨM (PRODUCTS)
    // =====================================
    private void ToggleAddProductForm() 
    {
        if (isAddingProduct) ResetProductForm();
        else isAddingProduct = true;
    }
    
    private void ResetProductForm()
    {
        newProduct = new Product();
        isAddingProduct = false;
        isEditingProduct = false;
        editingProductId = 0;
    }

    private void ShowEditProductForm(Product p)
    {
        isAddingProduct = true;
        isEditingProduct = true;
        editingProductId = p.Id;
        
        newProduct = new Product
        {
            Id = p.Id,
            Name = p.Name,
            Price = p.Price,
            CategoryId = p.CategoryId
        };
    }

    private async Task HandleSaveProduct()
    {
        if (string.IsNullOrWhiteSpace(newProduct.Name) || newProduct.CategoryId == 0)
        {
            await JSRuntime.InvokeVoidAsync("alert", "⚠️ Vui lòng nhập tên món và chọn danh mục!");
            return;
        }
        
        bool success;
        if (isEditingProduct)
        {
            success = await ApiService.UpdateProductAsync(editingProductId, newProduct);
        }
        else
        {
            success = await ApiService.CreateProductAsync(newProduct);
        }

        if (success)
        {
            await JSRuntime.InvokeVoidAsync("alert", "✅ Lưu sản phẩm thành công!");
            ResetProductForm();
            await LoadData();
        }
        else
        {
            await JSRuntime.InvokeVoidAsync("alert", "❌ Lỗi: Không thể lưu sản phẩm!");
        }
    }

    private async Task HandleDeleteProduct(int id)
    {
        bool confirm = await JSRuntime.InvokeAsync<bool>("confirm", "⚠️ Bạn có chắc chắn muốn XÓA món ăn này không?");
        if (!confirm) return;

        bool success = await ApiService.DeleteProductAsync(id);
        if (success) 
        {
            await JSRuntime.InvokeVoidAsync("alert", "✅ Đã xóa món ăn thành công!");
            await LoadData();
        }
        else
        {
            await JSRuntime.InvokeVoidAsync("alert", "❌ Lỗi: Không thể xóa món ăn này!");
        }
    }

    // =====================================
    // LOGIC DANH MỤC (CATEGORIES)
    // =====================================
    private void ToggleAddCategoryForm() 
    {
        if (isAddingCategory) ResetCategoryForm();
        else isAddingCategory = true;
    }

    private void ResetCategoryForm()
    {
        newCategory = new Category();
        isSubCategory = false;
        selectedParentId = 0;
        isAddingCategory = false;
        isEditingCategory = false;
        editingCategoryId = 0;
    }

    private void ShowEditCategoryForm(Category cat)
    {
        isAddingCategory = true;
        isEditingCategory = true;
        editingCategoryId = cat.Id;

        newCategory = new Category
        {
            Id = cat.Id,
            Name = cat.Name,
            ParentId = cat.ParentId
        };

        isSubCategory = cat.ParentId != null;
        selectedParentId = cat.ParentId ?? 0;
    }

    private async Task HandleSaveCategory()
    {
        if (string.IsNullOrWhiteSpace(newCategory.Name))
        {
            await JSRuntime.InvokeVoidAsync("alert", "⚠️ Vui lòng nhập tên danh mục!");
            return;
        }

        newCategory.ParentId = isSubCategory && selectedParentId != 0 ? selectedParentId : null;
        
        bool success;
        
        if (isEditingCategory)
        {
            success = await ApiService.UpdateCategoryAsync(editingCategoryId, newCategory);
        }
        else
        {
            success = await ApiService.CreateCategoryAsync(newCategory);
        }

        if (success)
        {
            await JSRuntime.InvokeVoidAsync("alert", "✅ Lưu danh mục thành công!");
            ResetCategoryForm();
            await LoadData();
        }
        else
        {
            await JSRuntime.InvokeVoidAsync("alert", "❌ Lỗi: Không thể lưu danh mục!");
        }
    }

    private async Task HandleDeleteCategory(int id)
    {
        bool confirm = await JSRuntime.InvokeAsync<bool>("confirm", "⚠️ Bạn có chắc chắn muốn XÓA danh mục này? Lưu ý: Mọi món ăn bên trong có thể sẽ bị xóa theo!");
        if (!confirm) return;

        bool success = await ApiService.DeleteCategoryAsync(id);
        if (success) 
        {
            await JSRuntime.InvokeVoidAsync("alert", "✅ Đã xóa danh mục thành công!");
            await LoadData();
        }
        else
        {
            await JSRuntime.InvokeVoidAsync("alert", "❌ Lỗi: Không thể xóa danh mục này!");
        }
    }
}