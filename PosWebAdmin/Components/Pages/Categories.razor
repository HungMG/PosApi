@page "/categories"
@using PosWebAdmin.Models
@using PosWebAdmin.Services
@inject ApiService ApiService

<div class="container-fluid mt-4">
    <h3 class="mb-4 fw-bold text-primary">Quản Lý Danh Mục</h3>

    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-dark text-white fw-bold">
                    Thêm Danh Mục Mới
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Tên danh mục</label>
                        <input type="text" class="form-control" @bind="newCategory.Name" placeholder="Ví dụ: Bún đậu, Trà trái cây..." />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Loại danh mục</label>
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="radio" name="catType" id="typeRoot"
                                   checked="@(!isSubCategory)" @onchange="@(() => isSubCategory = false)" />
                            <label class="form-check-label text-primary fw-bold" for="typeRoot">
                                Danh mục Gốc (Ví dụ: Đồ ăn, Nước uống)
                            </label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="catType" id="typeSub"
                                   checked="@isSubCategory" @onchange="@(() => isSubCategory = true)" />
                            <label class="form-check-label text-success fw-bold" for="typeSub">
                                Danh mục Con (Nằm trong danh mục Gốc)
                            </label>
                        </div>
                    </div>

                    @if (isSubCategory)
                    {
                        <div class="mb-3 p-3 bg-light border border-success rounded">
                            <label class="form-label fw-bold text-dark">Thuộc danh mục cha nào?</label>
                            <select class="form-select border-success" @bind="newCategory.ParentId">
                                <option value="0">-- Bấm để chọn danh mục cha --</option>
                                @foreach (var parent in parentCategories)
                                {
                                    <option value="@parent.Id">@parent.Name</option>
                                }
                            </select>
                        </div>
                    }

                    <button class="btn btn-success w-100 fw-bold py-2 mt-2" @onclick="HandleSaveCategory">
                        LƯU DANH MỤC
                    </button>
                    
                    @if (!string.IsNullOrEmpty(statusMessage))
                    {
                        <div class="alert alert-warning mt-3 py-2 text-center fw-bold">@statusMessage</div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white fw-bold">
                    Cấu Trúc Danh Mục Hiện Tại
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover table-striped mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th style="width: 10%">ID</th>
                                <th style="width: 45%">Tên Danh Mục</th>
                                <th style="width: 45%">Cấp Độ</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (categories == null || !categories.Any())
                            {
                                <tr>
                                    <td colspan="3" class="text-center py-4 text-muted">Đang tải dữ liệu...</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var cat in categories)
                                {
                                    <tr>
                                        <td>@cat.Id</td>
                                        <td class="@(cat.ParentId != null ? "ps-5 text-success fw-bold" : "fw-bold text-primary")">
                                            @(cat.ParentId != null ? "↳ " : "") @cat.Name
                                        </td>
                                        <td>
                                            @if (cat.ParentId == null)
                                            {
                                                <span class="badge bg-primary">Danh mục Gốc</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-success">Con của: @cat.Parent?.Name</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private List<Category> categories = new();
    private List<Category> parentCategories = new();
    private Category newCategory = new();
    private string statusMessage = "";
    
    // Biến kiểm soát trạng thái ẩn/hiện của nút chọn danh mục cha
    private bool isSubCategory = false;

    protected override async Task OnInitializedAsync()
    {
        await ReloadData();
    }

    private async Task ReloadData()
    {
        categories = await ApiService.GetCategoriesAsync();
        parentCategories = categories.Where(c => c.ParentId == null).ToList();
    }

    private async Task HandleSaveCategory()
    {
        if (string.IsNullOrWhiteSpace(newCategory.Name))
        {
            statusMessage = "Bạn quên nhập tên danh mục kìa!";
            return;
        }

        // Logic xử lý cực mượt:
        if (!isSubCategory)
        {
            // Nếu là danh mục gốc, ép ParentId về null
            newCategory.ParentId = null;
        }
        else
        {
            // Nếu là danh mục con mà chưa chọn cha (bằng 0 hoặc null) thì báo lỗi
            if (newCategory.ParentId == null || newCategory.ParentId == 0)
            {
                statusMessage = "Vui lòng chọn danh mục cha từ danh sách xổ xuống!";
                return;
            }
        }

        statusMessage = "Đang xử lý...";
        
        bool success = await ApiService.CreateCategoryAsync(newCategory);

        if (success)
        {
            statusMessage = "Lưu thành công!";
            newCategory = new Category(); // Xóa trắng form
            isSubCategory = false; // Reset về trạng thái mặc định
            await ReloadData(); // Tải lại bảng ngay lập tức
        }
        else
        {
            statusMessage = "Lỗi kết nối. Vui lòng thử lại!";
        }
    }
}